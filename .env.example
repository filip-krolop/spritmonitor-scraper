# Spritmonitor Scraper Configuration

# Request settings
USER_AGENT=VroomBroom-DataBot/1.0 (data@vroombroom.app)
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0
RATE_LIMIT_WAIT=600
MAX_RETRIES=3
